# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model settings (used by app/services/advice_generation.py)
LLM_MODEL=gemini-flash-latest

# Text-to-speech / speech-to-text — no keys needed for gTTS or faster-whisper,
# both are free and don't require API credentials.

# Optional — powers the weather-based disease-risk note (Step 5).
# Get a free key (1000 calls/day, no card) at https://home.openweathermap.org/users/sign_up
# App works fine without this — the weather card just won't show.
OPENWEATHER_API_KEY=your_openweathermap_key_here
