# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model settings (used by app/services/advice_generation.py)
LLM_MODEL=gemini-flash-latest

# Text-to-speech / speech-to-text — no keys needed for gTTS or faster-whisper,
# both are free and don't require API credentials. Nothing else to configure here.
